# ---- moesekai v2 server configuration ----
# Copy to .env and fill in. Settings marked (seed) are written to the DB on
# first run only; afterward the admin UI is authoritative.

# --- Required ---
# Secret used to sign JWT session tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Master key for encrypting secret settings (LLM keys, backup credentials) at
# rest in SQLite. Without it, secrets cannot be stored. Keep it stable.
MOESEKAI_MASTER_KEY=change-me-too

# --- Server ---
PORT=9090
DB_PATH=./data/moesekai.db
DATA_DIR=./data
# Allowed origin for the console API (CORS). Set to your console URL in prod.
CONSOLE_ORIGIN=*
# Session lifetime in hours (default 168 = 7 days).
TOKEN_TTL_HOURS=168

# --- Initial admin (created only when no users exist) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Or legacy-style: TRANSLATOR_ACCOUNTS=admin:pw,editor:pw2 (first is admin)

# --- LLM (seed) ---
LLM_TYPE=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Upstream update detection (seed) ---
UPSTREAM_REPO=Team-Haruki/haruki-sekai-master
UPSTREAM_BRANCH=main
TRANSLATE_SCHEDULER_ENABLED=true
# Poll interval for current_version.json, in ms (default 5 min).
UPSTREAM_POLL_MS=300000
# Maintain a local git clone of the masterdata repo (avoids API rate limits).
UPSTREAM_USE_GIT=false

# --- GitHub backup (seed) ---
# Repo URL may embed a token: https://x-access-token:TOKEN@github.com/owner/repo.git
GIT_PUSH_REPO_URL=
GIT_PUSH_BRANCH=backup-translations

# --- S3 backup (seed) ---
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# --- Search index refresh (ms) ---
SEARCH_INDEX_DEBOUNCE_MS=3600000
SEARCH_INDEX_REFRESH_MS=3600000
